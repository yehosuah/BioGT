# App
NEXT_PUBLIC_APP_ENV=development

# Database
POSTGRES_HOST_PORT=55432
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/biogt

# Map provider: mapbox | maplibre | google | leaflet | arcgis
NEXT_PUBLIC_MAP_PROVIDER=maplibre

# Default viewport
NEXT_PUBLIC_DEFAULT_LAT=14.6349
NEXT_PUBLIC_DEFAULT_LNG=-90.5069
NEXT_PUBLIC_DEFAULT_ZOOM=12

# Provider credentials
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_ARCGIS_API_KEY=

# Provider style/tile configuration
NEXT_PUBLIC_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
NEXT_PUBLIC_TILE_URL_TEMPLATE=

# Operations
NEXT_PUBLIC_ENABLE_MAP_DEBUG=true
NEXT_PUBLIC_ENABLE_MAP_TELEMETRY=true
NEXT_PUBLIC_MAP_FIXTURE_MODE=false
