{
  "name": "biogt",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @biogt/web",
    "build": "npm run build --workspace @biogt/web",
    "lint": "npm run lint --workspace @biogt/web",
    "typecheck": "npm run typecheck --workspace @biogt/web",
    "optimize:svg": "mkdir -p apps/web/assets/map-icons/optimized && svgo -f apps/web/assets/map-icons/raw -o apps/web/assets/map-icons/optimized --config=svgo.config.mjs",
    "check:svg": "node scripts/check-map-svgs.mjs",
    "data:populate": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:${POSTGRES_HOST_PORT:-55432}/biogt} bash ./scripts/run-etl-python.sh -m biomap_gt_etl.cli load --replace-atlas-data",
    "data:backfill-media": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:${POSTGRES_HOST_PORT:-55432}/biogt} bash ./scripts/run-etl-python.sh -m biomap_gt_etl.cli backfill-media",
    "test": "npm run test:unit",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:web": "npm run test:unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:etl": "BIOGT_ETL_REQUIRE_PYTEST=1 bash ./scripts/run-etl-python.sh -m pytest workers/etl/tests",
    "test:all": "npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "svgo": "^4.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
